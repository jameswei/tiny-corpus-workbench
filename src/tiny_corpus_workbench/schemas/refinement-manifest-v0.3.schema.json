{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tcw/refinement-manifest-v0.3.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "milestone", "run_id", "created_at", "status", "revision_id", "origin_observation_id", "origin_observation_run_id", "source", "base", "diagnosis_id", "draft_id", "runtime", "artifacts"],
  "properties": {
    "schema_version": {"const": "tcw.refinement-manifest/v0.3"},
    "milestone": {"const": "v0.3"},
    "run_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["APPLIED", "REJECTED"]},
    "revision_id": {"oneOf": [{"$ref": "finding-set-v0.3.schema.json#/$defs/hash"}, {"type": "null"}]},
    "origin_observation_id": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
    "origin_observation_run_id": {"type": "string", "minLength": 1},
    "source": {"$ref": "diagnosis-manifest-v0.3.schema.json#/$defs/source"},
    "base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "subject_id", "canonical_document_path", "canonical_document_size", "canonical_document_sha256"],
      "properties": {
        "kind": {"enum": ["OBSERVATION", "REVISION"]},
        "subject_id": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
        "canonical_document_path": {"enum": ["docling/document.json", "prepared/document.json"]},
        "canonical_document_size": {"type": "integer", "minimum": 1},
        "canonical_document_sha256": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"}
      }
    },
    "diagnosis_id": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
    "draft_id": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
    "runtime": {"$ref": "diagnosis-manifest-v0.3.schema.json#/$defs/runtime"},
    "artifacts": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "media_type", "size", "sha256", "application_immutable"],
        "properties": {
          "path": {"enum": ["decision.json", "report.md", "transformation.json", "history.json", "prepared/document.json", "prepared/document.md"]},
          "role": {"enum": ["refinement-decision", "refinement-report", "transformation", "transformation-history", "prepared-document-json", "prepared-document-markdown"]},
          "media_type": {"enum": ["application/json", "text/markdown"]},
          "size": {"type": "integer", "minimum": 1},
          "sha256": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
          "application_immutable": {"const": true}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "APPLIED"}}},
      "then": {
        "properties": {
          "revision_id": {"$ref": "finding-set-v0.3.schema.json#/$defs/hash"},
          "artifacts": {"minItems": 6, "maxItems": 6}
        }
      },
      "else": {
        "properties": {
          "revision_id": {"type": "null"},
          "artifacts": {"minItems": 2, "maxItems": 2}
        }
      }
    }
  ]
}
